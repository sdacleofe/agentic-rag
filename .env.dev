# ── Dev overrides for local GPU laptop ─────────────────────────────────────
# Merge with .env: docker compose --env-file .env.dev up
# Or use docker compose -f docker-compose.yml -f docker-compose.dev.yml up

OLLAMA_BASE_URL=http://localhost:11434

# Upgrade to 8B model — fits in 16GB VGPU with room to spare (~7GB VRAM used)
MODEL_NAME=gemma4:e4b

# GPU-unlocked generation settings
NUM_CTX=8192
NUM_THREAD=8
NUM_PREDICT=1024

# Local data paths (relative — no Docker volume mapping needed for dev)
CHROMA_PATH=./data/chromadb
UPLOADS_PATH=./data/uploads
BM25_INDEX_PATH=./data/bm25_index.pkl
